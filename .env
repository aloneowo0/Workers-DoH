# =============================================================================
#  DoH Proxy v2 — 用户配置文件
#
#  使用方式：
#    1. 编辑本文件中的参数
#    2. 运行 node scripts/build-config.js 生成 config.js
#    3. 部署到 Cloudflare Workers
#
#  预设上游的 URL 和 EDNS 能力已内置，无需手写。
# =============================================================================


# ─────────────────────────────────────────────────────────────────────────────
#  上游配置
# ─────────────────────────────────────────────────────────────────────────────

# 预设上游开关（true = 启用 / false = 禁用）
GOOGLE=true
CLOUDFLARE_PUBLIC=true
QUAD9=true
ADGUARD=true
OPENDNS=true
YANDEX=false
DNSPOD=true
ALIDNS=true
360=false
NEXTDNS=true

# 自定义上游（格式：CUSTOM_<名称>=<DoH URL>）
# CUSTOM_MY=https://my-doh.example.com/dns-query


# ─────────────────────────────────────────────────────────────────────────────
#  竞速参数
# ─────────────────────────────────────────────────────────────────────────────

# 总超时（毫秒），超时后不再等待上游响应
HARD_TIMEOUT_MS=800

# ECS 保护窗口（毫秒），窗口内 ECS 上游响应优先返回
ECS_PROTECT_MS=20


# ─────────────────────────────────────────────────────────────────────────────
#  EDNS / ECS 配置
# ─────────────────────────────────────────────────────────────────────────────

# ECS 子网前缀长度（越小越精确）
ECS_PREFIX4=24
ECS_PREFIX6=56

# 应答 IP 黑名单（CIDR 空格分隔，命中后整包丢弃）
BLOCKED_CIDRS=127.0.0.0/8 0.0.0.0/32 ::/128 ::1/128


# ─────────────────────────────────────────────────────────────────────────────
#  地区优化解析
#  指定 REGION 后自动启用：优选 IP 替换、域名强制映射、ECH 注入
# ─────────────────────────────────────────────────────────────────────────────

# 目标地区（CN / 留空不启用地区优化）
REGION=CN

# 优选域名（解析此域名得到优化后的 CF edge IP）
PREFERRED_DOMAIN=cf.090227.xyz

# 强制映射域名（空格分隔，这些域名及其子域强制走优选 IP）
FORCE_REMAP_DOMAINS=twimg.com twitter.com x.com t.co

# CF ECH 配置获取域名（其 HTTPS type=65 记录提供 CF 通用 ECH，约 1 小时轮换）
ECH_FETCH_DOMAIN=cloudflare-ech.com
