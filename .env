# =============================================================================
#  DoH Proxy v2 — 用户配置文件
#
#  使用方式：
#    1. 编辑本文件中的参数
#    2. 运行 node scripts/build-config.js 生成 config.js
#    3. 部署到 Cloudflare Workers
#
#  预设上游的 URL 和 EDNS 能力已内置，无需手写。
# =============================================================================


# ─────────────────────────────────────────────────────────────────────────────
#  上游配置
# ─────────────────────────────────────────────────────────────────────────────

# 预设上游开关（true = 启用 / false = 禁用）
GOOGLE=true
CLOUDFLARE_PUBLIC=true
QUAD9=true
ADGUARD=true
OPENDNS=true
YANDEX=false
DNSPOD=true
ALIDNS=true
360=false
NEXTDNS=true

# 自定义上游（格式：CUSTOM_<名称>=<DoH URL>）
# CUSTOM_MY=https://my-doh.example.com/dns-query


# ─────────────────────────────────────────────────────────────────────────────
#  竞速参数
# ─────────────────────────────────────────────────────────────────────────────

# 总超时（毫秒），超时后不再等待上游响应
HARD_TIMEOUT_MS=800

# ECS 保护窗口（毫秒），窗口内 ECS 上游响应优先返回
ECS_PROTECT_MS=20


# ─────────────────────────────────────────────────────────────────────────────
#  EDNS / ECS 配置
# ─────────────────────────────────────────────────────────────────────────────

# ECS 子网前缀长度（越小越精确）
ECS_PREFIX4=24
ECS_PREFIX6=56

# 应答 IP 黑名单（CIDR 空格分隔，命中后整包丢弃）
BLOCKED_CIDRS=127.0.0.0/8 0.0.0.0/32 ::/128 ::1/128


# =============================================================================
#  地区优化解析
# 每个地区一块配置，注释/取消注释整块即可开关
# REGION=XX 仅作可读标题，实际地区由 REGION_XX_* 键自动发现
# =============================================================================

REGION=CN
REGION_CN_PREFERRED=cf.090227.xyz
REGION_CN_REMAP=twimg.com twitter.com x.com t.co
REGION_CN_ECH=true

#REGION=RU
#REGION_RU_PREFERRED=cf.877774.xyz
#REGION_RU_REMAP=twimg.com twitter.com x.com t.co
#REGION_RU_ECH=true
