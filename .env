# =============================================================================
#  DoH Proxy v2 — 用户配置文件
#
#  使用方式：
#    1. 编辑本文件中的参数
#    2. 运行 node scripts/build-config.js 生成 config.js
#    3. 部署到 Cloudflare Workers / Vercel / EdgeOne Pages
#
#  预设上游的 URL 和 EDNS 能力已内置，无需手写。
#  自定义上游的 EDNS 能力由构建脚本自动探测。
# =============================================================================


# ---------------------------------------------------------------------------
#  预设上游开关
#  true = 启用  false = 禁用
#  启用后自动加入 mix 并发池，也可单独通过 /<名称>/query-dns 访问
# ---------------------------------------------------------------------------
GOOGLE=true
CLOUDFLARE=true
QUAD9=true
ADGUARD=true
OPENDNS=true
YANDEX=false          # EDNS 支持差，ecs/plus 会降级为 basic
DNSPOD=false
ALIDNS=false
360=false

# ---------------------------------------------------------------------------
#  自定义上游（可选）
#  格式：CUSTOM_<名称>=<DoH 端点 URL>
#  示例：CUSTOM_MY=https://my-doh.example.com/dns-query
#  名称只能包含字母、数字和下划线，会作为 /<名称>/query-dns 的路由段
#  构建时自动探测 EDNS（ecs / plus）支持情况
# ---------------------------------------------------------------------------
# CUSTOM_MY=https://my-doh.example.com/dns-query
# CUSTOM_OFFICE=https://dns.office.local/dns-query

# ---------------------------------------------------------------------------
#  超时控制
#
#  HARD_TIMEOUT_MS  — mix 并发总超时（毫秒）
#    超过此时间未响应的上游直接丢弃，不参与排序
#
#  GRACE_WINDOW_MS  — mix grace 窗口（毫秒）
#    第一个有效响应到达后，额外等待此窗口收集其他响应
#    窗口关闭后从收集到的响应中按优先级选最优返回
#    例外：最高优先级的上游到达时立即返回，不等窗口
# ---------------------------------------------------------------------------
HARD_TIMEOUT_MS=800
GRACE_WINDOW_MS=80

# ---------------------------------------------------------------------------
#  EDNS Client-Subnet (ECS) 前缀长度
#  发送给上游的子网掩码位数，越小越精确但也越暴露客户端位置
#  ECS_PREFIX4  — IPv4 前缀（默认 /24，/0 = 不发送位置）
#  ECS_PREFIX6  — IPv6 前缀（默认 /56）
# ---------------------------------------------------------------------------
ECS_PREFIX4=24
ECS_PREFIX6=56

# ---------------------------------------------------------------------------
#  Mix 并发优先级排序
#
#  当多个上游在 grace 窗口内返回有效答案时，按此顺序选择。
#  格式：上游名称（空格分隔），必须与预设/自定义的名称一致。
#
#  PRIORITY_ECS     — ECS 启用时的排序
#    mode=auto/plus 或客户端已带 ECS 时使用
#    ECS 支持好的上游排前面，不支持的排后面
#
#  PRIORITY_NO_ECS  — 无 ECS 时的排序
#    mode=keep 且客户端无 ECS 时使用
# ---------------------------------------------------------------------------
PRIORITY_ECS=google quad9 opendns adguard alidns dnspod 360 cloudflare yandex
PRIORITY_NO_ECS=cloudflare google quad9 opendns adguard alidns dnspod yandex 360

# ---------------------------------------------------------------------------
#  应答 IP 黑名单（CIDR 格式，空格分隔）
#  上游返回的 A/AAAA 记录命中以下范围时整包丢弃，返回 SERVFAIL
#  默认拦截：127.0.0.0/8（回环） 0.0.0.0/32（空地址） ::/128 和 ::1/128（IPv6 回环）
# ---------------------------------------------------------------------------
BLOCKED_CIDRS=127.0.0.0/8 0.0.0.0/32 ::/128 ::1/128
