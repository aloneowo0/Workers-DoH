# =============================================
#  DoH Proxy v2 — 用户配置
#  改完运行 scripts/build-config.js 生成 config.js
# =============================================

# ---------- 预设上游（true=启用 false=关闭）----------
GOOGLE=true
CLOUDFLARE=true
QUAD9=true
ADGUARD=true
OPENDNS=true
YANDEX=false
DNSPOD=false
ALIDNS=false
360=false

# ---------- 自定义上游（CUSTOM_名称=URL，可多行）----------
# CUSTOM_MY=https://my-doh.example.com/dns-query
# CUSTOM_OFFICE=https://dns.office.local/dns-query

# ---------- 超时参数 ----------
HARD_TIMEOUT_MS=800
GRACE_WINDOW_MS=80

# ---------- ECS 子网掩码 ----------
ECS_PREFIX4=24
ECS_PREFIX6=56

# ---------- Mix 优先级（空格分隔）----------
# ECS 启用时：ecs 支持的在前，不支持的在后
PRIORITY_ECS=google quad9 opendns adguard alidns dnspod 360 cloudflare yandex
# 无 ECS 时
PRIORITY_NO_ECS=cloudflare google quad9 opendns adguard alidns dnspod yandex 360

# ---------- 应答过滤（CIDR，空格分隔）----------
BLOCKED_CIDRS=127.0.0.0/8 0.0.0.0/32 ::/128 ::1/128
